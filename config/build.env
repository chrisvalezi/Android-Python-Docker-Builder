# Versoes pinadas para reproducibilidade do build.

PYTHON_VERSION=3.12.12
PYTHON_URL=https://www.python.org/ftp/python/3.12.12/Python-3.12.12.tgz

# ABI principal. Pode ser sobrescrita com:
# ANDROID_ABI=x86_64|arm64-v8a|armeabi-v7a|x86
ANDROID_ABI="${ANDROID_ABI:-x86_64}"

# Pode ser deixado vazio para derivacao automatica a partir do ABI.
ANDROID_TRIPLE="${ANDROID_TRIPLE:-}"

# API baseline. Pode ser sobrescrita por ambiente.
ANDROID_API="${ANDROID_API:-24}"

ANDROID_NDK_VERSION=r27d
ANDROID_NDK_URL=https://dl.google.com/android/repository/android-ndk-r27d-linux.zip

OPENSSL_VERSION=3.0.14
OPENSSL_URL=https://www.openssl.org/source/openssl-3.0.14.tar.gz

ZLIB_VERSION=1.3.1
ZLIB_URL=https://zlib.net/fossils/zlib-1.3.1.tar.gz

BZIP2_VERSION=1.0.8
BZIP2_URL=https://sourceware.org/pub/bzip2/bzip2-1.0.8.tar.gz

XZ_VERSION=5.4.6
XZ_URL=https://github.com/tukaani-project/xz/releases/download/v5.4.6/xz-5.4.6.tar.gz

LIBFFI_VERSION=3.4.6
LIBFFI_URL=https://github.com/libffi/libffi/releases/download/v3.4.6/libffi-3.4.6.tar.gz

SQLITE_VERSION=3460000
SQLITE_AUTOCONF=sqlite-autoconf-3460000
SQLITE_URL=https://www.sqlite.org/2024/sqlite-autoconf-3460000.tar.gz

LIBXML2_VERSION=2.15.2
LIBXML2_URL=https://download.gnome.org/sources/libxml2/2.15/libxml2-2.15.2.tar.xz

LIBXSLT_VERSION=1.1.45
LIBXSLT_URL=https://download.gnome.org/sources/libxslt/1.1/libxslt-1.1.45.tar.xz

RUNTIME_PREFIX=/opt/android-python

# Variantes geradas por padrao no empacotamento.
PACKAGE_VARIANTS="${PACKAGE_VARIANTS:-full minimal slim}"

# Pacotes Python puros preinstalados no runtime final.
BUNDLED_PYTHON_PACKAGES="${BUNDLED_PYTHON_PACKAGES:-faker requests jinja2}"

# Pacotes com extensoes nativas preinstalados no runtime final.
#
# numpy e pandas nao podem ser instalados como pacotes puros: eles precisam de
# wheels compiladas para Android, CPython e ABI corretos. Coloque essas wheels em
# output/wheelhouse/<abi>/ ou sobrescreva ANDROID_WHEELHOUSE_DIR.
NUMPY_VERSION="${NUMPY_VERSION:-2.2.6}"
PANDAS_VERSION="${PANDAS_VERSION:-2.2.3}"
PILLOW_VERSION="${PILLOW_VERSION:-12.2.0}"
LXML_VERSION="${LXML_VERSION:-6.0.3}"
UIAUTOMATOR2_VERSION="${UIAUTOMATOR2_VERSION:-3.5.0}"
BUNDLED_NATIVE_PYTHON_PACKAGES="${BUNDLED_NATIVE_PYTHON_PACKAGES:-numpy==${NUMPY_VERSION} pandas==${PANDAS_VERSION} Pillow==${PILLOW_VERSION} lxml==${LXML_VERSION} uiautomator2==${UIAUTOMATOR2_VERSION}}"
ANDROID_WHEELHOUSE_DIR="${ANDROID_WHEELHOUSE_DIR:-}"
ANDROID_WHEEL_PLATFORM_TAG="${ANDROID_WHEEL_PLATFORM_TAG:-}"
